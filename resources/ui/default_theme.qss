/* сЃўсЃФсЃЌсЂесЂІсЂ«жЃетѕє */
MainWindow > QMenuBar{
    background-color: #000000;
    color: #ffffff;
}

/* mainwindowсЂ«toolbar */
MainWindow > QToolBar{
    background-color: #dddddd;
    color: #555555;
}

MainWindow > QToolBar > QLabel#title{
     color: #008eaa;
     font-family: Bauhaus 93;
     font-size: 20pt;
}

MainWindow > QTabBar{
   background-color: #008eaa;
   qproperty-drawBase:0;
}

/* mainwindowсЂ«сѓхсѓцсЃЅсѓ┐сЃќ */
MainWindow > QTabBar::tab{
     background-color: #008eaa;
     color: #ffffff;
}

/* mainwindowсЂ«сѓхсѓцсЃЅсѓ┐сЃќ */
MainWindow > QTabBar::tab:selected{
     background-color: #99bbbbbb;
     color: #ffffff;
}

MapEditor2DView,RoomEditTool { 
    /* WallColor FieldColor CollisionColor InflationColor1 InflationColor2 */
    qproperty-colorScheme : "#FF008eaa #FFCCCCFF #FFD8737F #FFCCCCFF #FFFFCCCC";
}

